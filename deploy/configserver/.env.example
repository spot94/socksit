# Copy to .env.dev / .env.test / .env.prod (these are gitignored — never commit
# real secrets, SEC-1). Each environment gets its OWN password and volume so
# dev/test/prod stay independent (DEPL-3).

# Bootstrap admin password on first run. Leave empty to set it via the first-run
# web page instead. In prod prefer a docker secret over a plain env value.
ADMIN_PASSWORD=

# true only behind a TLS-terminating reverse proxy (prod). Dev stays false.
SECURE_COOKIES=false
